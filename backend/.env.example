# ── Application ───────────────────────────────────────────────────────────
APP_NAME="My Backbone App"
APP_URL="http://localhost:8000"
ENVIRONMENT="development"   # development | production | testing

# ── Security ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="change-me-in-production-use-a-256-bit-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (MongoDB) ─────────────────────────────────────────────────────
MONGODB_URL="mongodb://localhost:27017"
DATABASE_NAME="backbone_app"

# ── Redis (cache + task queue) ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300
TASK_QUEUE_NAME="backbone:tasks"
WORKER_CONCURRENCY=4

# ── Email (SMTP) ───────────────────────────────────────────────────────────
# Set EMAIL_ENABLED=true and fill SMTP fields below for real delivery.
# Welcome email runs on every successful /auth/register and on first Google sign-up.
EMAIL_ENABLED=false
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USERNAME=""
EMAIL_PASSWORD=""
EMAIL_FROM_ADDRESS="no-reply@yourapp.com"
EMAIL_FROM_NAME="Your App"

# ── Email Verification Flow ────────────────────────────────────────────────
# When true, new users still receive the welcome email plus verify_email (if token issued).
REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# ── Google Sign-In (same Web client as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend)
# In Google Cloud Console → OAuth client → add Authorized JavaScript origins:
#   http://localhost:3000  http://127.0.0.1:3000
# Authorized redirect URIs (for auth-code / popup flow):
#   postmessage
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GOOGLE_OAUTH_REDIRECT_URI="postmessage"

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ── Default Admin User (seeded on first startup) ───────────────────────────
# Change these immediately in production!
ADMIN_EMAIL="admin@yourapp.com"
ADMIN_PASSWORD="change-this-admin-password"

# ── Media / File Storage ───────────────────────────────────────────────────
MEDIA_ROOT="media"
MEDIA_URL_PREFIX="/media"

# ── Admin Panel ────────────────────────────────────────────────────────────
ADMIN_PREFIX="/admin"
